# API Django (local / red / tunnel)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
# DJANGO_INTERNAL_URL=http://127.0.0.1:8000

# Django
# SECRET_KEY=  # obligatorio si DEBUG=False
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# DB_NAME=totalliving_db
# DB_USER=postgres
# DB_PASSWORD=  # obligatorio si DEBUG=False
# DB_HOST=localhost
# DB_PORT=5432

# Auth panel (token DRF + cookie Next, misma ventana)
# AUTH_TOKEN_TTL_SECONDS=604800

# Django Admin (Fase 1)
# ADMIN_URL=admin/                    # ej. tl-panel-x7k/
# ADMIN_ALLOWED_IPS=127.0.0.1         # vacío = sin filtro; en prod lista IPs

# Cache compartido + IP detrás de Next (PR1 / A1+A2) — docs/SECURITY_FASE3.md
# REDIS_URL=redis://127.0.0.1:6379/1  # opcional; si no, prod usa DatabaseCache
# TRUSTED_PROXY_IPS=127.0.0.1,::1     # peers que pueden fijar X-Real-IP / XFF
# Tras DatabaseCache en prod: python manage.py createcachetable

# Producción HTTPS (solo aplican con DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# CSRF_TRUSTED_ORIGINS=https://tudominio.com
# CORS_ALLOWED_ORIGINS=https://tudominio.com   # obligatorio en prod (sin regex ngrok)
# ALLOWED_HOSTS=tudominio.com,www.tudominio.com  # en prod se eliminan hosts ngrok

# Media (Fase 2) — guía: docs/MEDIA_SECURITY.md
# MEDIA_SERVE_FROM_DJANGO=True   # False automático si usas S3/R2

# S3 / Cloudflare R2 — guía paso a paso: docs/S3_MEDIA.md
# Con AWS_STORAGE_BUCKET_NAME definido, Django sube imágenes/PDF al bucket.
# AWS_STORAGE_BUCKET_NAME=totalliving-media
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=us-east-1
# AWS_LOCATION=media
# AWS_QUERYSTRING_AUTH=False
# Dominio público (recomendado): CloudFront, R2 custom domain o *.r2.dev
# AWS_S3_CUSTOM_DOMAIN=media.tudominio.com
# MEDIA_URL=https://media.tudominio.com/media/
# Solo R2 (endpoint S3-compatible):
# AWS_S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Next (opcional): hostname del CDN para next/image
# NEXT_PUBLIC_MEDIA_CDN_HOST=media.tudominio.com

# Alertas seguridad (Fase 3) — docs/SECURITY_FASE3.md
# SECURITY_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# SECURITY_LOGIN_FAIL_ALERT_THRESHOLD=5
# SECURITY_LEAD_SPIKE_THRESHOLD=20

# Google Maps Platform
# Puede ir en .env o .env.local (Next.js lee ambos).
# Guía: docs/GOOGLE_MAPS_FASE1.md (restringe referrers + solo Maps JS API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Opcional: Map ID de Cloud Console (si no, usa DEMO_MAP_ID)
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# WhatsApp flotante (sitio público, desktop)
# NEXT_PUBLIC_WHATSAPP_PHONE=524421234567
# O URL completa:
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/524421234567
